<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>GD Player</title>

<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
<script src="https://cdn.plyr.io/3.7.8/plyr.js"></script>

<style>
body {
  background: #0f172a;
  color: white;
  font-family: Arial;
  text-align: center;
  padding: 20px;
}
.container {
  max-width: 900px;
  margin: auto;
}
input {
  width: 75%;
  padding: 10px;
  border-radius: 8px;
  border: none;
}
button {
  padding: 10px 15px;
  border: none;
  border-radius: 8px;
  background: #22c55e;
  color: white;
  font-weight: bold;
}
video {
  width: 100%;
  margin-top: 20px;
  border-radius: 10px;
}
</style>
</head>

<body>

<div class="container">
  <h2>🎬 GD Player Clone</h2>

  <input type="text" id="gdrive" placeholder="Paste link Google Drive di sini">
  <button onclick="loadVideo()">Play</button>

  <video id="player" controls></video>
</div>

<script>
const player = new Plyr('#player');

function loadVideo() {
  let link = document.getElementById("gdrive").value;

  // Ambil FILE ID Google Drive
  let id = null;

  if (link.includes("/file/d/")) {
    id = link.split("/file/d/")[1].split("/")[0];
  } else if (link.includes("id=")) {
    id = link.split("id=")[1];
  }

  if (!id) {
    alert("Link tidak valid!");
    return;
  }

  // 🔥 UBAH KE LINK WORKER
  const worker = "https://vod.ukielaki88.workers.dev/?id=" + id;

  // set video
  const video = document.getElementById("player");
  video.src = worker;
  video.play();
}
</script>

</body>
</html>
